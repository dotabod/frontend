{
  "name": "dotabod-frontend",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "format": "vp fmt",
    "dev": "doppler run -- next dev",
    "pull": "doppler run -- npx prisma db pull",
    "pull:tunnel": "./scripts/db-tunnel.sh npx prisma db pull",
    "push": "doppler run -- npx prisma db push",
    "push:tunnel": "./scripts/db-tunnel.sh npx prisma db push",
    "studio": "doppler run -- npx prisma studio",
    "studio:tunnel": "./scripts/db-tunnel.sh npx prisma studio",
    "build": "prisma generate && prisma generate --schema=./prisma-mongo/schema.prisma && next build",
    "build-local": "doppler run -- npm run build",
    "start": "next start",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc --noEmit",
    "parse": "i18next -c ./i18next-parser.config.mjs",
    "postinstall": "npm run generate:all && lefthook install || true",
    "knip": "knip",
    "test": "npm run vitest",
    "test:watch": "npm run vitest watch",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=4096' npm run vitest run --coverage",
    "vitest": "vp test run",
    "generate:postgres": "npx prisma generate",
    "generate:mongo": "npx prisma generate --schema=./prisma-mongo/schema.prisma",
    "generate:all": "npm run generate:postgres && npm run generate:mongo",
    "mongo:pull": "doppler run -- npx prisma db pull --schema=./prisma-mongo/schema.prisma",
    "mongo:push": "doppler run -- npx prisma db push --schema=./prisma-mongo/schema.prisma",
    "mongo:studio": "doppler run -- npx prisma studio --schema=./prisma-mongo/schema.prisma"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.24.0",
    "@ant-design/icons": "^6.1.0",
    "@csstools/postcss-oklab-function": "^4.0.12",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@mantine/core": "^7.17.8",
    "@mantine/form": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@next/third-parties": "^16.2.6",
    "@nowpaymentsio/nowpayments-api-js": "^1.0.5",
    "@prisma/client": "^6.19.0",
    "@reduxjs/toolkit": "^2.11.0",
    "@sentry/nextjs": "^10.54.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@twurple/eventsub-base": "7.2.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.0",
    "antd": "^6.4.3",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "curse-filter": "^6.0.0",
    "dayjs": "^1.11.19",
    "dotaconstants": "github:dotabod/dotaconstants#70fffb95a5951dae2ea80b183c8c1170a52da6f1",
    "focus-visible": "^5.2.1",
    "framer-motion": "^12.23.25",
    "graphql-request": "^7.3.5",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.487.0",
    "mantine-flagpack": "^4.1.1",
    "next": "^16.2.6",
    "next-auth": "4.24.14",
    "next-mdx-remote": "^6.0.0",
    "node-fetch": "^2.7.0",
    "obs-websocket-js": "^5.0.7",
    "opennode": "^1.5.0",
    "postcss-focus-visible": "^10.0.1",
    "react": "19.1.0",
    "react-countdown": "^2.3.6",
    "react-countdown-circle-timer": "^3.2.1",
    "react-dom": "19.1.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "retry": "^0.13.1",
    "socket.io-client": "^4.8.1",
    "stripe": "18.0.0",
    "styled-components": "^6.1.19",
    "swr": "^2.3.7",
    "tailwindcss": "^4.1.17",
    "twitch-fetcher": "https://github.com/dotabod/twitch-fetcher.git",
    "use-debounce": "^10.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.1",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@types/retry": "^0.12.5",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "knip": "^6.14.2",
    "lefthook": "^2.1.6",
    "node-mocks-http": "^1.17.2",
    "postcss": "^8.5.6",
    "prisma": "^6.19.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "browserslist": "defaults, not ie <= 11",
  "packageManager": "pnpm@11.2.2"
}
